		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\HR.Library\HR.Library.csproj" />
		<ProjectReference Include="..\..\..\libs\spark\MintPlayer.Spark\MintPlayer.Spark.csproj" />
