{
  "name": "@mintplayer/ng-spark-auth",
  "private": false,
  "version": "0.2.0",
  "description": "Angular authentication library for MintPlayer.Spark",
  "repository": {
    "type": "git",
    "url": "https://github.com/MintPlayer/MintPlayer.Spark",
    "directory": "node_packages/ng-spark-auth"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "@angular/core": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@mintplayer/ng-bootstrap": "^21.12.4",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {},
  "sideEffects": false,
  "module": "./dist/fesm2022/mintplayer-ng-spark-auth.mjs",
  "typings": "./dist/types/mintplayer-ng-spark-auth.d.ts",
  "exports": {
    "./package.json": { "default": "./package.json" },
    ".": {
      "types": "./dist/types/mintplayer-ng-spark-auth.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth.mjs"
    },
    "./auth-bar": {
      "types": "./dist/types/mintplayer-ng-spark-auth-auth-bar.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-auth-bar.mjs"
    },
    "./core": {
      "types": "./dist/types/mintplayer-ng-spark-auth-core.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-core.mjs"
    },
    "./forgot-password": {
      "types": "./dist/types/mintplayer-ng-spark-auth-forgot-password.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-forgot-password.mjs"
    },
    "./guards": {
      "types": "./dist/types/mintplayer-ng-spark-auth-guards.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-guards.mjs"
    },
    "./interceptors": {
      "types": "./dist/types/mintplayer-ng-spark-auth-interceptors.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-interceptors.mjs"
    },
    "./login": {
      "types": "./dist/types/mintplayer-ng-spark-auth-login.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-login.mjs"
    },
    "./models": {
      "types": "./dist/types/mintplayer-ng-spark-auth-models.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-models.mjs"
    },
    "./pipes": {
      "types": "./dist/types/mintplayer-ng-spark-auth-pipes.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-pipes.mjs"
    },
    "./register": {
      "types": "./dist/types/mintplayer-ng-spark-auth-register.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-register.mjs"
    },
    "./reset-password": {
      "types": "./dist/types/mintplayer-ng-spark-auth-reset-password.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-reset-password.mjs"
    },
    "./routes": {
      "types": "./dist/types/mintplayer-ng-spark-auth-routes.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-routes.mjs"
    },
    "./two-factor": {
      "types": "./dist/types/mintplayer-ng-spark-auth-two-factor.d.ts",
      "default": "./dist/fesm2022/mintplayer-ng-spark-auth-two-factor.mjs"
    }
  }
}
