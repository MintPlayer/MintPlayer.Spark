{
  "private": true,
  "description": "Root package.json - npm workspaces monorepo. Single node_modules for all Angular projects.",
  "scripts": {
    "test:ng-spark": "npm --workspace @mintplayer/ng-spark run test",
    "test:ng-spark-auth": "npm --workspace @mintplayer/ng-spark-auth run test",
    "test:ng": "npm run test:ng-spark && npm run test:ng-spark-auth",
    "test:affected": "nx affected --target=test",
    "test": "nx run-many --target=test"
  },
  "workspaces": [
    "libs/node_packages/ng-spark",
    "libs/node_packages/ng-spark-auth",
    "Demo/DemoApp/DemoApp/ClientApp",
