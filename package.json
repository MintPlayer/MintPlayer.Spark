{
  "private": true,
  "description": "Root package.json - npm workspaces monorepo. Single node_modules for all Angular projects.",
  "scripts": {
    "test:ng-spark": "npm --workspace @mintplayer/ng-spark run test",
    "test:ng-spark-auth": "npm --workspace @mintplayer/ng-spark-auth run test",
    "test:ng": "npm run test:ng-spark && npm run test:ng-spark-auth",
    "test:affected": "nx affected --target=test --exclude=@spark-demo/*,DemoApp,DemoApp.Library,Fleet,Fleet.Library,HR,HR.Library,WebhooksDemo,WebhooksDemo.Library",
    "test": "nx run-many --target=test --exclude=@spark-demo/*,DemoApp,DemoApp.Library,Fleet,Fleet.Library,HR,HR.Library,WebhooksDemo,WebhooksDemo.Library"
  },
  "workspaces": [
    "node_packages/ng-spark",
    "node_packages/ng-spark-auth",
    "Demo/DemoApp/DemoApp/ClientApp",
    "Demo/Fleet/Fleet/ClientApp",
    "Demo/HR/HR/ClientApp",
    "Demo/WebhooksDemo/WebhooksDemo/ClientApp"
  ],
  "dependencies": {
    "@angular/animations": "21.1.6",
    "@angular/common": "21.1.6",
    "@angular/compiler": "21.1.6",
    "@angular/core": "21.1.6",
    "@angular/forms": "21.1.6",
    "@angular/platform-browser": "21.1.6",
    "@angular/router": "21.1.6",
    "@mintplayer/dailymotion-player": "^19.0.0",
    "@mintplayer/file-player": "^19.0.0",
    "@mintplayer/ng-animations": "21.1.0",
    "@mintplayer/ng-bootstrap": "^21.12.4",
    "@mintplayer/ng-spark-auth": "^0.0.7",
    "@mintplayer/ng-video-player": "^21.0.0",
    "@mintplayer/pagination": "^2.3.0",
    "@mintplayer/player-progress": "^19.0.0",
    "@mintplayer/player-provider": "^19.0.0",
    "@mintplayer/soundcloud-player": "^19.0.0",
    "@mintplayer/video-player": "^19.0.0",
    "@mintplayer/vimeo-player": "^19.0.0",
    "@mintplayer/youtube-player": "^19.0.0",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.8",
    "@analogjs/vitest-angular": "^2.4.8",
    "@angular-devkit/build-angular": "^21.2.8",
    "@angular/build": "21.1.5",
    "@angular/cli": "21.1.5",
    "@angular/compiler-cli": "21.1.6",
    "@nx/angular": "22.6.5",
    "@vitest/coverage-v8": "4.0.16",
    "jsdom": "27.3.0",
    "ng-packagr": "21.1.0",
    "nx": "22.6.5",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "overrides": {
    "@angular/core": "21.1.6",
    "@angular/common": "21.1.6",
    "@angular/router": "21.1.6",
    "@angular/forms": "21.1.6",
    "@angular/platform-browser": "21.1.6",
    "@angular/animations": "21.1.6",
    "@angular/cdk": "21.1.6"
  }
}
